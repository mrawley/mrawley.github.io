---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('writing', ({ data }) => {
  return !data.draft;
});
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Writing | Megan Lange">
  <p class="mono accent">$ ls writing/</p>
  <h1>Writing</h1>

  {
    allPosts.length === 0 ? (
      <p class="dim mono">$ echo "no posts published yet, check back soon."</p>
    ) : (
      <ul class="posts">
        {allPosts.map((post) => (
          <li>
            <p class="meta mono dim">
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </p>
            <h3>
              <a href={`/writing/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>

<style>
  .posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .posts > li + li {
    margin-top: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--border);
  }
  .meta {
    margin: 0 0 0.25rem;
    font-size: 0.85rem;
  }
  h3 {
    margin-top: 0;
  }
  h3::before {
    content: none;
  }
</style>
