---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects | Megan Lange">
  <p class="eyebrow">Projects</p>
  <h1>Projects</h1>

  {projects.length === 0 ? (
    <p class="dim">No projects published yet, check back soon.</p>
  ) : (
    <ul class="bento">
      {projects.map((p, i) => (
        <li class={(i === 0 || i === projects.length - 1) && projects.length >= 4 ? 'wide' : ''}>
          <div class="year mono">{p.data.year}</div>
          <h3>{p.data.title}</h3>
          {p.data.role && <span class="role">{p.data.role}</span>}
          <p>{p.data.description}</p>
          {p.data.stack && p.data.stack.length > 0 && (
            <ul class="tags">
              {p.data.stack.map((s) => <li>{s}</li>)}
            </ul>
          )}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  /* Projects: variant J (bento asymmetric grid) */
  .bento {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }
  .bento > li {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .bento > li:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px var(--accent-glow);
  }
  .bento > li.wide {
    grid-column: 1 / -1;
    border-left: 3px solid var(--accent);
  }
  .bento .year {
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .bento h3 {
    margin: 0;
    color: var(--text-primary);
    font-size: 1.15rem;
  }
  .bento h3::before {
    content: '';
  }
  .bento .role {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .bento p {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .bento .tags {
    list-style: none;
    padding: 0;
    margin: var(--space-sm) 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .bento .tags li {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    background: var(--accent-glow);
    border-radius: 4px;
    padding: 0.3rem 0.6rem;
    line-height: 1;
  }
  @media (max-width: 640px) {
    .bento {
      grid-template-columns: 1fr;
    }
    .bento > li.wide {
      grid-column: 1;
    }
  }
</style>
